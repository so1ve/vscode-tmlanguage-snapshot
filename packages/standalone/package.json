{
  "name": "vscode-tmlanguage-snapshot",
  "version": "1.0.1",
  "author": "Ray <i@mk1.io> (@so1ve)",
  "type": "module",
  "description": "Take snapshots of your tmLanguage grammar.",
  "keywords": [
    "grammar",
    "highlighting",
    "snapshot",
    "snapshot-testing",
    "syntax",
    "textmate",
    "tmLanguage",
    "vscode"
  ],
  "homepage": "https://github.com/so1ve/vscode-tmlanguage-snapshot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/so1ve/vscode-tmlanguage-snapshot.git",
    "directory": "packages/standalone"
  },
  "bugs": {
    "url": "https://github.com/so1ve/vscode-tmlanguage-snapshot/issues"
  },
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch"
  },
  "dependencies": {
    "@vscode-tmlanguage-snapshot/core": "workspace:",
    "vscode-oniguruma": "catalog:",
    "vscode-textmate": "catalog:"
  }
}
